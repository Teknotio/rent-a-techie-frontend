{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/_next/*", "/images/*", "/favicon.ico", "/*.png", "/*.jpg", "/*.jpeg", "/*.gif", "/*.svg"]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".html": "text/html"
  },
  "globalHeaders": {
    "cache-control": "public, max-age=3600"
  }
}
